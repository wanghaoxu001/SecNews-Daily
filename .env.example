# PostgreSQL
POSTGRES_USER=secnews
POSTGRES_PASSWORD=secnews_dev_password
POSTGRES_DB=secnews

# Backend
DATABASE_URL=postgresql+asyncpg://secnews:secnews_dev_password@postgres:5432/secnews
JWT_SECRET=change-me-to-a-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
LOG_LEVEL=INFO

# Crawl4AI
CRAWL_BROWSER_TYPE=chromium
CRAWL_HEADLESS=true
CRAWL_PAGE_TIMEOUT_MS=45000
CRAWL_MAX_RETRIES=2
CRAWL_WAIT_FOR=css:article, main, [role='main']
CRAWL_MIN_CONTENT_LEN=200
CRAWL_MAX_CONTENT_LEN=5000
CRAWL_SIMULATE_USER=true
CRAWL_MAGIC=true
CRAWL_CHECK_ROBOTS=false
CRAWL_USER_AGENT=SecNewsBot/1.0 (+https://example.com)
CRAWL_DOMAIN_OVERRIDES_JSON={"www.bleepingcomputer.com":{"timeouts_ms":[75000,90000,120000],"wait_for":["css:main, body","css:body","css:body"]}}
