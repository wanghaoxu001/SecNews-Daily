# PostgreSQL
POSTGRES_USER=secnews
POSTGRES_PASSWORD=secnews_dev_password
POSTGRES_DB=secnews

# Backend
DATABASE_URL=postgresql+asyncpg://secnews:secnews_dev_password@postgres:5432/secnews
JWT_SECRET=change-me-to-a-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_FILE_PATH=logs/backend.log
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=7

# Crawl4AI
CRAWL_BROWSER_TYPE=chromium
CRAWL_HEADLESS=true
CRAWL_PAGE_TIMEOUT_MS=45000
CRAWL_MAX_RETRIES=2
CRAWL_WAIT_FOR=css:article, main, [role='main']
CRAWL_MIN_CONTENT_LEN=200
CRAWL_MAX_CONTENT_LEN=5000
CRAWL_SIMULATE_USER=true
CRAWL_MAGIC=true
CRAWL_CHECK_ROBOTS=false
CRAWL_USER_AGENT=SecNewsBot/1.0 (+https://example.com)
CRAWL_DOMAIN_OVERRIDES_JSON={}
CRAWL_POLICY_PROBE_ENABLED=true
CRAWL_POLICY_PROBE_TRIGGER_ON_CREATE=true
CRAWL_POLICY_PROBE_SAMPLE_SIZE=3
CRAWL_POLICY_PROBE_CONCURRENCY=2
CRAWL_POLICY_CACHE_TTL_SECONDS=60
